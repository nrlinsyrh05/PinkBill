<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rosePink">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ Electricity Bill Estimator"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/darkText"
            android:layout_gravity="center"
            android:layout_marginBottom="25dp"/>

        <!-- Month -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Month"
            android:textStyle="bold"
            android:textColor="@color/darkText"/>

        <Spinner
            android:id="@+id/spMonth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:padding="10dp"/>

        <!-- Unit -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Electricity Unit Used (kWh)"
            android:textStyle="bold"
            android:textColor="@color/darkText"
            android:layout_marginTop="15dp"/>

        <EditText
            android:id="@+id/etUnit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter unit used (1 - 1000)"
            android:background="@color/white"
            android:padding="12dp"
            android:inputType="number"/>

        <!-- Rebate -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rebate Percentage (%)"
            android:textStyle="bold"
            android:textColor="@color/darkText"
            android:layout_marginTop="15dp"/>

        <EditText
            android:id="@+id/etRebate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="0 - 5"
            android:background="@color/white"
            android:padding="12dp"
            android:inputType="numberDecimal"/>

        <!-- Calculate -->

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculate"
            android:textColor="@color/white"
            android:backgroundTint="@color/buttonPink"
            android:layout_marginTop="20dp"/>

        <!-- Save -->

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Record"
            android:textColor="@color/white"
            android:backgroundTint="@color/pinkDark"
            android:layout_marginTop="10dp"/>

        <!-- View -->

        <Button
            android:id="@+id/btnView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Records"
            android:textColor="@color/white"
            android:backgroundTint="@color/buttonPink"
            android:layout_marginTop="10dp"/>

        <!-- About -->

        <Button
            android:id="@+id/btnAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About"
            android:textColor="@color/white"
            android:backgroundTint="@color/pinkDark"
            android:layout_marginTop="10dp"/>

        <!-- Result Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bill Summary"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/darkText"/>

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Charges: RM 0.00&#10;Final Cost: RM 0.00"
                    android:textSize="18sp"
                    android:textColor="@color/darkText"
                    android:paddingTop="10dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>